{
  "name": "lua-cli",
  "version": "1.3.1",
  "description": "Command-line interface for Lua AI platform - develop, test, and deploy LuaSkills with custom tools",
  "readmeFilename": "README.md",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./types": "./dist/types.js",
    "./skill": "./dist/skill.js",
    "./user-data-api": "./dist/user-data-api.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build:react": "cd src/web && npx tsx build.ts",
    "build": "npm run clean && npm run build:react && tsc && chmod +x dist/index.js && npm link",
    "prepublishOnly": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "lua",
    "ai",
    "cli",
    "command-line",
    "automation",
    "agents",
    "api",
    "typescript",
    "tools",
    "bundling",
    "testing",
    "deployment",
    "skills"
  ],
  "author": "Stefan Kruger <stefan@lua.dev>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lua-ai-global/lua-cli.git"
  },
  "homepage": "https://github.com/lua-ai-global/lua-cli#readme",
  "readme": "README.md",
  "bugs": {
    "url": "https://github.com/lua-ai-global/lua-cli/issues"
  },
  "engines": {
    "node": ">=16.0.0"
  },
  "files": [
    "dist/**/*",
    "template/**/*",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "dependencies": {
    "commander": "^14.0.1",
    "esbuild": "^0.25.10",
    "inquirer": "^12.9.6",
    "keytar": "^7.9.0",
    "node-fetch": "^3.3.2",
    "open": "^10.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io-client": "^4.7.2",
    "ws": "^8.18.3",
    "zod": "^4.1.9"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/jest": "^29.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.5.1",
    "@types/node-fetch": "^2.6.13",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/parser": "^8.44.1",
    "@typescript-eslint/typescript-estree": "^8.44.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  },
  "bin": {
    "lua": "dist/index.js"
  }
}
